{
  "$schema": "https://opencode.ai/config.json",
  
  "default_agent": "orchestrator",
  
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/deepseek",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-reasoner": {
          "name": "DeepSeek Reasoner",
          "reasoning": true,
          "tool_call": true
        },
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "tool_call": true
        }
      }
    }
  },
  
  "model": "deepseek/deepseek-reasoner",
  "small_model": "deepseek/deepseek-chat",
  
  "instructions": ["AGENTS.md"],
  
  "permission": {
    "edit": "ask",
    "bash": {
      "go build *": "allow",
      "go vet *": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "docker compose ps": "allow",
      "docker compose logs*": "allow",
      "psql *--list*": "allow",
      "psql *-c \"SELECT*": "allow",
      "rm -rf*": "deny",
      "*": "ask"
    }
  }
}
